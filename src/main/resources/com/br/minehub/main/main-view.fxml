<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.br.minehub.main.MainController"
            styleClass="app-bg">

    <left>
        <VBox styleClass="sidebar" spacing="8">
            <Label text="MineHub" styleClass="sidebar-title"/>

            <Separator/>

            <Button text="Arquivos" onAction="#showFiles" styleClass="nav-button"/>
            <Button text="Console" onAction="#showConsole" styleClass="nav-button"/>
            <Button text="Servidor" onAction="#showServer" styleClass="nav-button"/>
            <Button text="Configurações" onAction="#showSettings" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="page"/>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text="Desconectado"
               styleClass="status-bar"/>
    </bottom>

</BorderPane>