<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.br.minehub.main.MainController"
            styleClass="app-bg">

    <top>
        <HBox styleClass="topbar" spacing="10">
            <Pane HBox.hgrow="ALWAYS"/>

            <Label text="Servidor:" styleClass="muted-text"/>

            <ComboBox fx:id="serverSelector"
                      prefWidth="260"
                      promptText="Nenhum servidor"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="8">
            <Label text="MineHub" styleClass="sidebar-title"/>

            <Separator/>

            <Button text="Arquivos" onAction="#showFiles" styleClass="nav-button"/>
            <Button text="Terminal" onAction="#showTerminal" styleClass="nav-button"/>
            <Button text="Configurações" onAction="#showSettings" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="page"/>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text="Desconectado"
               styleClass="status-bar"/>
    </bottom>

</BorderPane>